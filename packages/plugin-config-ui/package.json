    "xstate": "^5.18.2"
  },
  "peerDependencies": {
    "@chakra-ui/react": "^3.36.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/react": "18.3.18",

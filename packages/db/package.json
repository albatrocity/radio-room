{
  "name": "@repo/db",
  "version": "1.0.0",
  "description": "Drizzle ORM schema and database client for the Listening Room platform",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "esbuild src/migrate.ts --bundle --platform=node --target=node22 --outfile=dist/migrate.js --external:pg --format=cjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.13"
  }
}

# Redis
REDIS_URL=redis://localhost:6379

# Express session
SESSION_SECRET=change-me-to-a-random-string

# Spotify OAuth (required for Spotify rooms)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/spotify/callback

# Tidal OAuth (required for Tidal rooms)
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_REDIRECT_URI=http://127.0.0.1:3000/auth/tidal/callback

# Web app URL — open the browser at these hosts (not "localhost") so Spotify OAuth and session cookies match the API.
APP_URL=http://127.0.0.1:8000
VITE_API_URL=http://127.0.0.1:3000
# Production only: share invite cookie with API host (e.g. listeningroom.club or .listeningroom.club).
# VITE_AUTH_COOKIE_DOMAIN=.listeningroom.club
# Scheduler (docker compose): http://127.0.0.1:8001

# PostgreSQL (required for admin auth)
DATABASE_URL=postgresql://listening_room:listening_room@localhost:5432/listening_room

# Better-Auth (required for admin auth)
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars

# Google OAuth (optional, for admin Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Seed admin user (used by: npx tsx packages/db/src/seed.ts)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin

# Newsletter via Amazon SES (optional until newsletter feature is used)
# Sender identity must be a verified SES domain/address.
NEWSLETTER_FROM=Listening Room <news@yourdomain.com>
AWS_REGION=us-east-1
# Credentials: use standard AWS chain (env, shared config, or IAM role).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Secret used to sign one-click unsubscribe tokens (falls back to BETTER_AUTH_SECRET).
NEWSLETTER_UNSUBSCRIBE_SECRET=
# Comma-separated extra CORS origins for POST /api/newsletter/subscribe (e.g. archives site)
# NEWSLETTER_SUBSCRIBE_ORIGINS=https://listen.show
